<script type="text/javascript">
// Track how many items are currently shown
var newsItemsShown = 6;
var newsTotalItems = 21;
var newsBatchSize = 5;
var newsFirstPageLimit = 6;

// Toggle between compact and expanded views
function toggleView() {
  var newsList = document.querySelector('.news-list');
  var toggleBtn = document.getElementById('news-view-toggle');

  if (!newsList || !toggleBtn) return;

  if (newsList.classList.contains('compact')) {
    newsList.classList.remove('compact');
    newsList.classList.add('expanded');
    toggleBtn.textContent = 'Compact View';
  } else {
    newsList.classList.remove('expanded');
    newsList.classList.add('compact');
    toggleBtn.textContent = 'Expanded View';
  }
}

// Toggle individual news item between collapsed (2 lines) and expanded
function toggleNewsItem(item) {
  var contentDiv = item.querySelector('.news-content');
  if (!contentDiv) return;

  if (contentDiv.classList.contains('expanded')) {
    contentDiv.classList.remove('expanded');
  } else {
    contentDiv.classList.add('expanded');
  }
}

// Check if text is overflowing (more than 2 lines) and needs ellipsis
function checkNewsOverflow() {
  var items = document.querySelectorAll('.news-card');
  items.forEach(function(item) {
    var contentDiv = item.querySelector('.news-content');
    if (!contentDiv) return;

    // Check if content is taller than 2 lines (approximately 3em with line-height 1.5)
    var lineHeight = parseFloat(getComputedStyle(contentDiv).lineHeight);
    var maxHeight = lineHeight * 2;

    if (contentDiv.scrollHeight > maxHeight + 2) { // +2px tolerance
      contentDiv.setAttribute('data-has-overflow', 'true');
    }
  });
}

// Update the last visible item styling
function updateLastVisibleItem() {
  // Remove news-last-visible class from all items
  var allItems = document.querySelectorAll('.news-card');
  allItems.forEach(function(item) {
    item.classList.remove('news-last-visible');
  });

  // Find last visible item and add class
  var visibleItems = Array.from(allItems).filter(function(item) {
    return item.style.display !== 'none';
  });

  if (visibleItems.length > 0) {
    visibleItems[visibleItems.length - 1].classList.add('news-last-visible');
  }
}

function toggleNewsPivot(e) {
  if (e) e.preventDefault();

  var allHiddenItems = document.querySelectorAll('.news-hidden');
  var link = document.getElementById('news-toggle-link');
  if (!link) return false;

  // Get configurable text from data attributes
  var textMore = link.getAttribute('data-text-more') || 'More';
  var textCollapse = link.getAttribute('data-text-collapse') || 'Collapse';
  var batchSize = parseInt(link.getAttribute('data-batch-size')) || newsBatchSize;

  var isExpanded = link.getAttribute('aria-expanded') === 'true';

  if (isExpanded) {
    // Collapse: hide all items beyond first page limit
    allHiddenItems.forEach(function(item){ item.style.display = 'none'; });
    newsItemsShown = newsFirstPageLimit;
    link.setAttribute('aria-expanded','false');

    // Calculate remaining items
    var remaining = newsTotalItems - newsItemsShown;
    var toShow = Math.min(remaining, batchSize);
    link.textContent = 'See ' + toShow + ' more item' + (toShow === 1 ? '' : 's');
  } else {
    // Expand: show next batch of items
    var toShow = Math.min(newsItemsShown + batchSize, newsTotalItems);

    for (var i = 0; i < allHiddenItems.length; i++) {
      if (i < toShow - newsFirstPageLimit) {
        allHiddenItems[i].style.display = 'flex';
      }
    }

    newsItemsShown = toShow;

    // Update button text and aria-expanded state
    if (newsItemsShown >= newsTotalItems) {
      link.setAttribute('aria-expanded','true');
      link.textContent = textCollapse;
    } else {
      var remaining = newsTotalItems - newsItemsShown;
      var nextBatch = Math.min(remaining, batchSize);
      link.textContent = 'See ' + nextBatch + ' more item' + (nextBatch === 1 ? '' : 's');
    }
  }

  // Update last visible item styling
  updateLastVisibleItem();

  // Check overflow for newly visible items
  checkNewsOverflow();

  return false;
}

// Initialize overflow detection and last item styling when page loads
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', function() {
    updateLastVisibleItem();
    checkNewsOverflow();
  });
} else {
  updateLastVisibleItem();
  checkNewsOverflow();
}
</script>

