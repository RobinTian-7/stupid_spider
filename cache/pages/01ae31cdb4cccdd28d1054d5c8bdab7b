          (function(){
  function decode(coded, key) {
    var shift = coded.length;
    var link = '';
    for (var i = 0; i < coded.length; i++) {
      var ch = coded.charAt(i);
      var idx = key.indexOf(ch);
      if (idx === -1) {
        link += ch;
      } else {
        var ltr = (idx - shift + key.length) % key.length;
        link += key.charAt(ltr);
      }
    }
    return link;
  }

  // Decode email obfuscation
  var els = document.querySelectorAll('.email-obfuscate');
  els.forEach(function(el) {
    var coded = el.getAttribute('data-coded');
    var key = el.getAttribute('data-key');
    if (!coded || !key) return;
    var link = decode(coded, key);
    var a = document.createElement('a');
    a.href = 'mailto:' + link;
    var text = el.getAttribute('data-text');
    a.textContent = text && text.length ? text : link;
    // copy optional id/class from the placeholder onto the link
    if (el.id) a.id = el.id;
    if (el.className) {
      // remove the marker class 'email-obfuscate' when copying
      var cls = el.className.split(/\s+/).filter(function(c){ return c && c !== 'email-obfuscate'; }).join(' ');
      if (cls) a.className = cls;
    }
    el.parentNode.replaceChild(a, el);
  });

  // Show the missing URL path
  var pathEl = document.getElementById("missing-path");
  if (pathEl) {
    pathEl.textContent = window.location.origin + window.location.pathname;
  }
})();


