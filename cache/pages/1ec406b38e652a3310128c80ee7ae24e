            <div class="field field--name-image field--type-image field--label-hidden field__item">  <img loading="lazy" src="/sites/cse.umn.edu/files/styles/medium/public/ZK-headshot.JPG.webp?itok=SazGnoys" width="218" height="220" alt="Zeke-S-Headshot" class="image-style-medium" />


