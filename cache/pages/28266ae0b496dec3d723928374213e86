            <p class="infolinks">[<a href="javascript:toggleInfo('Lambert20','abstract')" onclick="javascript:pageTracker._trackPageview('/abstracts/Lambert20'); ">Abstract</a>] [<a href="javascript:toggleInfo('Lambert20','bibtex')">BibTeX</a>] 
