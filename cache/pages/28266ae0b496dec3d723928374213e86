  booktitle = {The NIPS Deep Rienforcement Learning Symposium},<br />   Title = &quot;Predictive State Decoders: Encoding the Future into Recurrent Networks&quot;,<br />   year = {2017}<br />}</pre></td>
          </tr>
			
			
			<tr id="Dai17b" class="entry">
