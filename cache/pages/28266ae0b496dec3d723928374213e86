            <p class="infolinks">[<a href="javascript:toggleInfo('Bhardwaj21A','abstract')" onclick="javascript:pageTracker._trackPageview('/abstracts/Bhardwaj21A'); ">Abstract</a>] [<a href="javascript:toggleInfo('Bhardwaj21A','bibtex')">BibTeX</a>] 
