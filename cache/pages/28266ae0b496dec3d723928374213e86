            <p class="infolinks"> [<a href="javascript:toggleInfo('Downey17a','abstract')" onclick="javascript:pageTracker._trackPageview('/abstracts/PSRNNs'); ">Abstract</a>]
				[<a href="javascript:toggleInfo('Downey17a','bibtex')">BibTeX</a>] [<a href="files/PSRNN_CoRL_2017.pdf" onclick="javascript:pageTracker._trackPageview('/downloads/PSRNN_CoRL'); ">PDF</a>]
