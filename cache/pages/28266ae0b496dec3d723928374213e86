<p class="infolinks"> [<a href="javascript:toggleInfo('Cheng16b','abstract')" onclick="javascript:pageTracker._trackPageview('/abstracts/IVSGPRNIPSWorkshop2016'); ">Abstract</a>] [<a href="javascript:toggleInfo('Cheng16b','bibtex')">BibTeX</a>] [<a href="files/IVSGPR-NIPSWS.pdf"  onclick="javascript:pageTracker._trackPageview('/downloads/IVSGPRNIPSWorkshop2016'); ">PDF</a>]</p></td>
