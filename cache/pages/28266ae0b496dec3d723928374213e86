            <p class="infolinks">[<a href="javascript:toggleInfo('Yan21A','abstract')" onclick="javascript:pageTracker._trackPageview('/abstracts/Yan21A'); ">Abstract</a>] [<a href="javascript:toggleInfo('Yan21A','bibtex')">BibTeX</a>] 
