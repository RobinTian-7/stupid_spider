		 <tr id="Barcelos21A" class="entry">
            <td> L. Barcelos, A. Lambert, R. Oliveira, P. Borges, <strong>B. Boots</strong>, &amp; Fabio Ramos.</td>
				<td><strong>Dual Online Stein Variational Inference for Control and Dynamics.</strong> 
            <p class="infolinks">[<a href="javascript:toggleInfo('Barcelos21A','abstract')" onclick="javascript:pageTracker._trackPageview('/abstracts/Barcelos21A'); ">Abstract</a>] [<a href="javascript:toggleInfo('Barcelos21A','bibtex')">BibTeX</a>] 
