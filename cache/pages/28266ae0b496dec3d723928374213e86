		 	[<a href="javascript:toggleInfo('Cheng18b','bibtex')">BibTeX</a>] [<a href="files/LOKI.pdf" onclick="javascript:pageTracker._trackPageview('/downloads/LOKI'); ">PDF</a>] [<a href="https://arxiv.org/abs/1805.10413" onclick="javascript:pageTracker._trackPageview('/downloads/LOKIarxiv'); ">arXiv</a>]
