          <tr id="Boots1ld" class="entry">
            <td><strong>B. Boots</strong> &amp; G. J. Gordon.</td>
            <td><strong>Two-Manifold Problems.</strong>
              <p class="infolinks"> [<a href="javascript:toggleInfo('Boots11d','abstract')" onclick="javascript:pageTracker._trackPageview('/abstracts/2ManifoldARXIV'); ">Abstract</a>]
                [<a href="javascript:toggleInfo('Boots11d','bibtex')">BibTeX</a>]
