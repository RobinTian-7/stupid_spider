year      = {2019}
}
</pre>
</td>
</tr>
		  <tr id="Sun19a" class="entry">
           <td>W. Sun, A. Vemula, <strong>B. Boots</strong>, &amp J. A. Bagnell.</td>
            <td><strong>Provably Efficient Imitation Learning from Observation Alone</strong>. <span class="style1">(Selected for Long Talk: 5% Acceptance Rate)</span>
