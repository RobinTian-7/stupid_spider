            [<a href="javascript:toggleInfo('Sun18b','bibtex')">BibTeX</a>] [<a href="files/DPI.pdf" onclick="javascript:pageTracker._trackPageview('/downloads/DPI'); ">PDF</a>] [<a href="files/DPI_Supplimentary.pdf">Appendix</a>] [<a href="https://arxiv.org/abs/1805.10755" onclick="javascript:pageTracker._trackPageview('/downloads/DPIArxiv'); ">arXiv</a>] 
