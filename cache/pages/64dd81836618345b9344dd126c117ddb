  <style>
    :root {
      --navy: #1a2744;
      --navy-mid: #2d3f6b;
      --accent: #c8893a;
      --accent-light: #f0dfc0;
      --text: #1e1e1e;
      --text-muted: #555;
      --border: #ddd;
      --bg: #faf9f7;
      --white: #fff;
      --link: #1a56cc;
      --sidebar-w: 260px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      font-size: 17px;
      line-height: 1.7;
      color: var(--text);
      background: var(--bg);
    }

    a { color: var(--link); text-decoration: none; }
    a:hover { color: var(--accent); text-decoration: underline; }

    /* ââ NAV ââ */
    header {
      background: var(--navy);
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 1px 8px rgba(0,0,0,0.18);
    }
    nav {
      max-width: 1080px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      gap: 8px;
      height: 54px;
    }
    .nav-brand {
      font-family: 'EB Garamond', serif;
      font-size: 17px;
      color: #fff;
      font-weight: 500;
      letter-spacing: 0.3px;
      margin-right: auto;
    }
    .nav-brand:hover { text-decoration: none; color: var(--accent-light); }
    nav ul { list-style: none; display: flex; gap: 4px; }
    nav ul a {
      color: rgba(255,255,255,0.82);
      font-size: 15.5px;
      font-weight: 500;
      padding: 6px 13px;
      border-radius: 4px;
      transition: background 0.18s, color 0.18s;
    }
    nav ul a:hover {
      background: rgba(255,255,255,0.12);
      color: #fff;
      text-decoration: none;
    }
    nav ul a.active {
      background: var(--accent);
      color: #fff;
    }

    /* ââ LAYOUT ââ */
    .page-wrap {
      max-width: 1080px;
      margin: 0 auto;
      padding: 40px 24px 64px;
      display: grid;
      grid-template-columns: var(--sidebar-w) 1fr;
      gap: 40px;
      align-items: start;
    }

    /* ââ SIDEBAR ââ */
    .sidebar {
      position: sticky;
      top: 74px;
    }
    .sidebar-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .sidebar-photo {
      width: 100%;
      aspect-ratio: 4/5;
      object-fit: cover;
      object-position: top center;
      display: block;
    }
    .sidebar-body {
      padding: 18px 20px 22px;
    }
    .sidebar-name {
      font-family: 'EB Garamond', serif;
      font-size: 21px;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 3px;
      line-height: 1.2;
    }
    .sidebar-role {
      font-size: 15px;
      font-weight: 500;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.6px;
      margin-bottom: 14px;
    }
    .sidebar-info {
      font-size: 15px;
      color: var(--text-muted);
      line-height: 1.9;
    }
    .sidebar-info a { color: var(--link); }
    .sidebar-divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 14px 0;
    }
    .sidebar-contact {
      font-size: 14.5px;
      color: var(--text-muted);
      line-height: 2;
    }
    .sidebar-contact strong { color: var(--text); font-weight: 600; }
    .sidebar-links {
      margin-top: 14px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .sidebar-links a {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      font-size: 14.5px;
      font-weight: 500;
      color: var(--link);
      padding: 6px 11px;
      border: 1px solid var(--border);
      border-radius: 5px;
      background: var(--bg);
      transition: border-color 0.15s, background 0.15s;
    }
    .sidebar-links a:hover {
      border-color: var(--navy-mid);
      background: #fff;
      text-decoration: none;
    }

    /* ââ MAIN ââ */
    main { min-width: 0; }

    /* ââ SECTIONS ââ */
    section { margin-bottom: 40px; }
    .section-heading {
      font-family: 'EB Garamond', serif;
      font-size: 24px;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 14px;
      padding-bottom: 9px;
      border-bottom: 2px solid var(--accent);
      display: flex;
      align-items: center;
      gap: 9px;
    }
    .section-heading .icon {
      width: 20px;
      height: 20px;
      opacity: 0.7;
    }

    /* ââ BIO ââ */
    .bio-text p {
      font-size: 16.5px;
      line-height: 1.8;
      color: #333;
      margin-bottom: 12px;
      text-align: justify;
    }
    .bio-text p:last-child { margin-bottom: 0; }

    /* ââ RESEARCH AREAS ââ */
    .research-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }
    .research-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 9px;
      padding: 18px 16px 16px;
      box-shadow: 0 1px 6px rgba(0,0,0,0.05);
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .research-card:hover {
      box-shadow: 0 4px 18px rgba(0,0,0,0.1);
      transform: translateY(-2px);
    }
    .card-icon {
      font-size: 22px;
      margin-bottom: 8px;
      display: block;
    }
    .card-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 6px;
      line-height: 1.3;
    }
    .card-desc {
      font-size: 16px;
      color: var(--text-muted);
      line-height: 1.6;
    }
    .card-tag {
      display: inline-block;
      margin-top: 10px;
      font-size: 13px;
      font-weight: 600;
      color: var(--accent);
      background: var(--accent-light);
      border-radius: 4px;
      padding: 2px 8px;
      letter-spacing: 0.3px;
    }

    /* ââ NEWS ââ */
    .news-list { list-style: none; }
    .news-item {
      display: grid;
      grid-template-columns: 110px 1fr;
      gap: 14px;
      padding: 12px 0;
      border-bottom: 1px solid #eee;
      align-items: baseline;
    }
    .news-item:last-child { border-bottom: none; }
    .news-date {
      font-size: 16px;
      font-weight: 600;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.4px;
      white-space: nowrap;
    }
    .news-text {
      font-size: 16px;
      color: #333;
      line-height: 1.6;
    }
    .news-text a { color: var(--link); font-weight: 500; }
    .badge {
      display: inline-block;
      font-size: 12px;
      font-weight: 700;
      padding: 1px 7px;
      border-radius: 3px;
      text-transform: uppercase;
      letter-spacing: 0.4px;
      margin-right: 4px;
    }
    .badge-new { background: #e8f5e9; color: #2e7d32; }
    .badge-paper { background: #e3f0fb; color: #1565c0; }
    .badge-talk { background: #fce4ec; color: #c62828; }
    .badge-release { background: #fff3e0; color: #e65100; }

    /* ââ TALKS ââ */
    .talks-list { list-style: none; }
    .talk-item {
      display: grid;
      grid-template-columns: 1fr;
      padding: 13px 0;
      border-bottom: 1px solid #eee;
    }
    .talk-item:last-child { border-bottom: none; }
    .talk-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--navy);
      line-height: 1.5;
      margin-bottom: 3px;
    }
    .talk-venue {
      font-size: 15px;
      color: var(--text-muted);
    }

    /* ââ FOOTER ââ */
    footer {
      background: var(--navy);
      color: rgba(255,255,255,0.5);
      text-align: center;
      font-size: 14.5px;
      padding: 20px;
      margin-top: 40px;
    }
    footer a { color: rgba(255,255,255,0.6); }

    /* ââ RESPONSIVE ââ */
    @media (max-width: 760px) {
      .page-wrap {
        grid-template-columns: 1fr;
        padding: 24px 16px 48px;
      }
      .sidebar { position: static; }
      .impact-bar { grid-template-columns: repeat(2, 1fr); }
      .research-cards { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 480px) {
      .research-cards { grid-template-columns: 1fr; }
      .impact-bar { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
