<script>
jQuery(window).on('load', function () {

  function trySync() {
    const leftEl  = document.querySelector('#left-carousel .swiper');
    const rightEl = document.querySelector('#right-carousel .swiper');

    if (!leftEl || !rightEl) return;

    const left  = leftEl.swiper;
    const right = rightEl.swiper;

    if (!left || !right) return;

    // prevent duplicate sync
    if (left.__synced === right) return;

    left.controller.control = right;
    left.__synced = right;

    console.log('Swipers synced');
  }

  // Try repeatedly because Elementor rebuilds sliders
  const observer = new MutationObserver(() => {
    trySync();
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true
  });

  // Initial attempt
  trySync();

});




</script>

