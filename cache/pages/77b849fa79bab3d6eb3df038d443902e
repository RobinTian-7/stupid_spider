  <style>
    :root {
      --navy: #1a2744;
      --navy-mid: #2d3f6b;
      --accent: #c8893a;
      --accent-light: #f0dfc0;
      --text: #1e1e1e;
      --text-muted: #555;
      --border: #ddd;
      --bg: #faf9f7;
      --white: #fff;
      --link: #1a56cc;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; font-size: 17px; line-height: 1.7; color: var(--text); background: var(--bg); }
    a { color: var(--link); text-decoration: none; }
    a:hover { color: var(--accent); text-decoration: underline; }

    header { background: var(--navy); position: sticky; top: 0; z-index: 100; box-shadow: 0 1px 8px rgba(0,0,0,0.18); }
    nav { max-width: 1080px; margin: 0 auto; padding: 0 24px; display: flex; align-items: center; gap: 8px; height: 54px; }
    .nav-brand { font-family: 'EB Garamond', serif; font-size: 17px; color: #fff; font-weight: 500; letter-spacing: 0.3px; margin-right: auto; }
    .nav-brand:hover { text-decoration: none; color: var(--accent-light); }
    nav ul { list-style: none; display: flex; gap: 4px; }
    nav ul a { color: rgba(255,255,255,0.82); font-size: 15.5px; font-weight: 500; padding: 6px 13px; border-radius: 4px; transition: background 0.18s, color 0.18s; }
    nav ul a:hover { background: rgba(255,255,255,0.12); color: #fff; text-decoration: none; }
    nav ul a.active { background: var(--accent); color: #fff; }

    .page-wrap { max-width: 860px; margin: 0 auto; padding: 44px 24px 72px; }
    .page-title { font-family: 'EB Garamond', serif; font-size: 30px; font-weight: 600; color: var(--navy); margin-bottom: 32px; }

    .section-heading {
      font-family: 'EB Garamond', serif;
      font-size: 24px;
      font-weight: 600;
      color: var(--navy);
      border-bottom: 2px solid var(--accent);
      padding-bottom: 8px;
      margin-bottom: 18px;
      margin-top: 40px;
    }
    .section-heading:first-of-type { margin-top: 0; }

    .member-list { list-style: none; }
    .member-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      padding: 11px 0;
      border-bottom: 1px solid #eee;
      align-items: start;
    }
    .member-item:last-child { border-bottom: none; }
    .member-name { font-size: 18px; font-weight: 600; color: var(--link); }
    .member-name.plain { color: var(--text); font-weight: 400; }
    a.member-name:hover { color: var(--accent); }
    .member-meta { font-size: 16px; color: var(--text-muted); margin-top: 2px; }
    .member-note { font-size: 16px; color: var(--text-muted); font-style: italic; margin-top: 2px; }
    .highlight { color: var(--accent); font-style: normal; font-weight: 600; }

    .tag {
      display: inline-block;
      font-size: 15px;
      font-weight: 600;
      color: var(--white);
      border-radius: 4px;
      padding: 2px 9px;
      white-space: nowrap;
      margin-top: 2px;
    }
    .tag-rf   { background: #1565c0; }
    .tag-phd  { background: #283593; }
    .tag-msc  { background: #006064; }
    .tag-vis  { background: #4a148c; }
    .tag-alum { background: #546e7a; }

    .member-awards {
      margin-top: 5px;
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }
    .award-pill {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 16px;
      font-weight: 500;
      color: #7a4f00;
      background: #fff8ed;
      border: 1px solid #f0dfc0;
      border-radius: 20px;
      padding: 2px 9px 2px 7px;
      white-space: nowrap;
    }
    .award-pill::before {
      content: "ГўВҳВ…";
      font-size: 9px;
      color: var(--accent);
    }

    footer { background: var(--navy); color: rgba(255,255,255,0.5); text-align: center; font-size: 14.5px; padding: 20px; margin-top: 40px; }

    @media (max-width: 520px) {
      .member-item { grid-template-columns: 1fr; }
    }
  </style>
</head>
