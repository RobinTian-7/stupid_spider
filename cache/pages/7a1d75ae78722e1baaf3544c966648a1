    <!-- Scroll to Top JavaScript -->
    <script type="text/javascript">
        // Scroll to Top Button Functionality
(function() {
  const scrollToTopBtn = document.getElementById('scrollToTop');
  const scrollThreshold = 300;

  if (!scrollToTopBtn) return;

  // Show/hide button based on scroll position
  function handleScroll() {
    if (window.scrollY > scrollThreshold) {
      scrollToTopBtn.classList.add('visible');
    } else {
      scrollToTopBtn.classList.remove('visible');
    }
  }

  // Scroll to top when button is clicked
  function scrollToTop() {
    window.scrollTo({
      top: 0,
      behavior: 'smooth'
    });
  }

  // Event listeners
  window.addEventListener('scroll', handleScroll);
  scrollToTopBtn.addEventListener('click', scrollToTop);

  // Initial check
  handleScroll();
})();


    </script>

    <!-- Analytics Event Tracking -->
    
    <script type="text/javascript">
        // Analytics Event Tracking — Event Delegation
// Included in default.html, runs on all pages.
// Uses null-safe access since delegation roots only exist on specific pages.
(function() {
  'use strict';

  if (typeof gtag !== 'function') return;

  // Helper: extract paper slug from URL path (optional trailing slash)
  function getPaperSlug() {
    var match = window.location.pathname.match(/\/papers\/([^\/]+)\/?/);
    return match ? match[1] : '';
  }

  // ================================================================
  // PAPER PAGE: Outbound link click tracking
  // Listens on .links-section for clicks on .text-link elements.
  // Handles both <a class="text-link"> and <span class="text-link">
  // (the latter contains a nested <a> from markdownified content).
  // ================================================================
  var linksSection = document.querySelector('.links-section');
  if (linksSection) {
    linksSection.addEventListener('click', function(e) {
      // Find the closest .text-link (works for both <a> and <span>)
      var textLink = e.target.closest('.text-link');
      if (!textLink) return;

      // Determine the actual anchor element
      var anchor = (textLink.tagName === 'A') ? textLink : textLink.querySelector('a');
      if (!anchor) return;

      // Read link type from .profile-label text
      var label = textLink.querySelector('.profile-label');
      var labelText = label ? label.textContent.trim() : '';
      // For markdown-rendered labels, the <a> is inside .profile-label;
      // extract just the text content (strips the nested link text)
      if (label && label.querySelector('a')) {
        labelText = label.querySelector('a').textContent.trim();
      }

      // Normalize label to snake_case link_type
      var typeMap = {
        'pdf': 'pdf',
        'arxiv': 'arxiv',
        "publisher's page": 'publisher',
        'reviews': 'reviews',
        'github': 'code',
        'python package': 'package',
        'google scholar': 'google_scholar',
        'semantic scholar': 'semantic_scholar'
      };
      var linkType = typeMap[labelText.toLowerCase()] || labelText.toLowerCase().replace(/\s+/g, '_');

      gtag('event', 'paper_link_click', {
        link_type: linkType,
        paper_slug: getPaperSlug(),
        link_url: anchor.href.substring(0, 100)
      });
    });
  }

  // ================================================================
  // PAPER PAGE: Topic tag clicks
  // ================================================================
  var topicTags = document.querySelector('.topic-tags-list');
  if (topicTags) {
    topicTags.addEventListener('click', function(e) {
      var tag = e.target.closest('.topic-tag-link');
      if (!tag) return;

      gtag('event', 'topic_tag_click', {
        topic: tag.textContent.trim().toLowerCase(),
        paper_slug: getPaperSlug()
      });
    });
  }

  // ================================================================
  // PAPER LISTING: Card link clicks
  // Uses data-slug attribute on .paper-card for reliable slug extraction.
  // ================================================================
  var papersContainer = document.getElementById('papers-container');
  if (papersContainer) {
    papersContainer.addEventListener('click', function(e) {
      var link = e.target.closest('a');
      if (!link) return;

      var card = link.closest('.paper-card');
      if (!card) return;

      var slug = card.getAttribute('data-slug') || '';

      // Determine link type from context
      var linkType = 'title';
      var tag = link.closest('.paper-card-tag');
      if (tag) {
        linkType = link.textContent.trim().toLowerCase().replace(/\s+/g, '_');
      }

      gtag('event', 'paper_card_click', {
        paper_slug: slug,
        link_type: linkType
      });
    });
  }
})();

    </script>
    
