<script>

    function setNavPositions() {
        const header = document.querySelector('.site-header');
        const mobileNav = document.getElementById('mobile-nav-menu');
        const overlay = document.getElementById('nav-overlay');
        if (!header || !mobileNav || !overlay) return;
        const headerHeight = header.getBoundingClientRect().height;
        mobileNav.style.top = headerHeight + 'px';
        overlay.style.top = headerHeight + 'px';
        // Ensure proper stacking
        mobileNav.style.zIndex = '350';
        overlay.style.zIndex = '200';
    }

    function toggleNav() {
        const mobileNav = document.getElementById('mobile-nav-menu');
        const hamburger = document.getElementById('hamburger-btn');
        const overlay = document.getElementById('nav-overlay');
        setNavPositions();
        const isOpen = mobileNav.classList.toggle('active');
        hamburger.classList.toggle('active');
        overlay.classList.toggle('active');
        hamburger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    }

    function closeNav() {
        document.getElementById('mobile-nav-menu').classList.remove('active');
        document.getElementById('hamburger-btn').classList.remove('active');
        document.getElementById('nav-overlay').classList.remove('active');
        document.getElementById('hamburger-btn').setAttribute('aria-expanded', 'false');
    }

    document.addEventListener('DOMContentLoaded', function () {
        // Initialize positions
        setNavPositions();

        // Toggle handlers
        document.getElementById('hamburger-btn').addEventListener('click', toggleNav);
        document.querySelectorAll('#mobile-nav-menu .page-link').forEach(link => {
            link.addEventListener('click', closeNav);
        });

        // Update positions on resize/orientation changes
        window.addEventListener('resize', setNavPositions);
    });


</script>
    
