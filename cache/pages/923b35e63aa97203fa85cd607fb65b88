            <div class="field field--name-field-image field--type-entity-reference field--label-hidden field__item">  <div class="field__item">    <img loading="lazy" srcset="/sites/default/files/styles/cinema_small_620_1x/public/2025-11/viplogo-square_0.jpg?h=8a06940a&amp;itok=_v2yEQxn 426w, /sites/default/files/styles/cinema_small_1024_1x/public/2025-11/viplogo-square_0.jpg?h=8a06940a&amp;itok=UWF7e3Ik 450w, /sites/default/files/styles/cinema_small_default_1x/public/2025-11/viplogo-square_0.jpg?h=8a06940a&amp;itok=5CVxjjcw 543w, /sites/default/files/styles/cinema_small_620_1_5x/public/2025-11/viplogo-square_0.jpg?h=8a06940a&amp;itok=TkhprrOp 639w, /sites/default/files/styles/cinema_small_1024_1_5x/public/2025-11/viplogo-square_0.jpg?h=8a06940a&amp;itok=rdtyYyuP 675w, /sites/default/files/styles/cinema_small_default_1_5x/public/2025-11/viplogo-square_0.jpg?h=8a06940a&amp;itok=TyHcyXrH 815w, /sites/default/files/styles/cinema_small_620_2x/public/2025-11/viplogo-square_0.jpg?h=8a06940a&amp;itok=mM7H5zrY 852w, /sites/default/files/styles/cinema_small_1024_2x/public/2025-11/viplogo-square_0.jpg?h=8a06940a&amp;itok=cDc-9-Wl 900w, /sites/default/files/styles/cinema_small_default_2x/public/2025-11/viplogo-square_0.jpg?h=8a06940a&amp;itok=QWBzHn43 1086w" sizes="(min-width: 620px) 42vw, (min-width: 1024px) 25vw, 88vw" width="543" height="305" src="/sites/default/files/styles/cinema_small_default_1x/public/2025-11/viplogo-square_0.jpg?h=8a06940a&amp;itok=5CVxjjcw" alt="VIP Logo" />


