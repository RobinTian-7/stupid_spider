      <hr class="my-5">            <div id="chapter-id-26422" class="paragraph paragraph--type--chapter paragraph--view-mode--default">
          
          <h2 class="field__label">Undergraduate Research </h2>
    
      <div class="field field--name-field-structured-body field--type-entity-reference-revisions field--label-hidden field__items">
              <div class="field__item">  <div class="paragraph paragraph--type--styled-text paragraph--view-mode--default">
          
            <div class="clearfix text-formatted field field--name-field-styled-text field--type-text-long field--label-hidden field__item"><h3>Summer Research Programs at NYU Tandon</h3>
<p><strong>For NYU Students &amp; Select Students from Other Universities</strong><br><br />
Each summer, members of NYU Tandon faculty open up their labs to allow rising junior and senior undergraduate students 10 weeks of hands-on research under faculty mentorship.</p>
</div>
      
      </div>
</div>
              <div class="field__item">



  <div class="paragraph paragraph--type--call-to-action paragraph--view-mode--default">

    
      <div class="row">

                  <div class="col-12 col-lg-6">
            
          
            <div class="field field--name-field-image field--type-entity-reference field--label-hidden field__item">  <div class="field__item">    <img loading="lazy" srcset="/sites/default/files/styles/cinema_small_620_1x/public/2019-07/img_2011_1.jpg?h=71976bb4&amp;itok=eehygOGO 426w, /sites/default/files/styles/cinema_small_1024_1x/public/2019-07/img_2011_1.jpg?h=71976bb4&amp;itok=sshK5xC0 450w, /sites/default/files/styles/cinema_small_default_1x/public/2019-07/img_2011_1.jpg?h=71976bb4&amp;itok=bEwS_41y 543w, /sites/default/files/styles/cinema_small_620_1_5x/public/2019-07/img_2011_1.jpg?h=71976bb4&amp;itok=AzDArFnb 639w, /sites/default/files/styles/cinema_small_1024_1_5x/public/2019-07/img_2011_1.jpg?h=71976bb4&amp;itok=cvkPegxk 675w, /sites/default/files/styles/cinema_small_default_1_5x/public/2019-07/img_2011_1.jpg?h=71976bb4&amp;itok=NHJinP4b 815w, /sites/default/files/styles/cinema_small_620_2x/public/2019-07/img_2011_1.jpg?h=71976bb4&amp;itok=z1rFoqRf 852w, /sites/default/files/styles/cinema_small_1024_2x/public/2019-07/img_2011_1.jpg?h=71976bb4&amp;itok=ohCvuHJL 900w, /sites/default/files/styles/cinema_small_default_2x/public/2019-07/img_2011_1.jpg?h=71976bb4&amp;itok=NShTcFRZ 1086w" sizes="(min-width: 620px) 42vw, (min-width: 1024px) 25vw, 88vw" width="543" height="305" src="/sites/default/files/styles/cinema_small_default_1x/public/2019-07/img_2011_1.jpg?h=71976bb4&amp;itok=bEwS_41y" alt="gloved hand and petri dishes" title="gloved hand and petri dishes" />


