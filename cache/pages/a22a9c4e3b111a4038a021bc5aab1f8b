      // Scramble text function
      function scrambleText(element) {
        // Arabic character set for scrambling
        const arabicChars = 'Ø¡Ø¢Ø£Ø¤Ø¥Ø¦Ø§Ø¨Ø©ØªØ«Ø¬Ø­Ø®Ø¯Ø°Ø±Ø²Ø³Ø´ØµØ¶Ø·Ø¸Ø¹ØºÙÙÙÙÙÙÙÙÙÙ';
        const latinChars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
        
        // Get all text nodes within the element
        const walker = document.createTreeWalker(
          element,
          NodeFilter.SHOW_TEXT,
          null,
          false
        );
        
        let nodes = [];
        let node;
        while (node = walker.nextNode()) {
          nodes.push(node);
        }
        
        // Scramble each text node
        nodes.forEach(textNode => {
          // Clear any existing interval for this node
          if (textNode.scrambleInterval) {
            clearInterval(textNode.scrambleInterval);
          }

          // Store original text if not already stored
          if (!textNode.originalText) {
            textNode.originalText = textNode.textContent;
          }

          let scrambledText = '';
          let revealedIndices = new Set();
          
          // Check if text contains Arabic characters
          const isArabic = /[\u0600-\u06FF]/.test(textNode.originalText);
          const chars = isArabic ? arabicChars : latinChars;
          
          // Create initial scrambled text
          for (let i = 0; i < textNode.originalText.length; i++) {
            scrambledText += chars.charAt(Math.floor(Math.random() * chars.length));
          }
          textNode.textContent = scrambledText;
          
          // Gradually reveal the original text in random order
          textNode.scrambleInterval = setInterval(() => {
            if (revealedIndices.size >= textNode.originalText.length) {
              clearInterval(textNode.scrambleInterval);
              return;
            }
            
            // Find a random unrevealed index
            let randomIndex;
            do {
              randomIndex = Math.floor(Math.random() * textNode.originalText.length);
            } while (revealedIndices.has(randomIndex));
            
            revealedIndices.add(randomIndex);
            scrambledText = scrambledText.substring(0, randomIndex) + 
                           textNode.originalText.charAt(randomIndex) + 
                           scrambledText.substring(randomIndex + 1);
            textNode.textContent = scrambledText;
          }, 75);
        });
      }

