          console.log($('#tableTop'))
          $('#secretButton').css('z-index', 0);
          $('#fullBody').css('position', 'absolute');
          $('#fullBody').animate({
            left : '1000px'
          }, 2000);
        }

        Main.closeTablet = function() {

          $('#fullBody').animate({
            left : '0px'
          }, 2000, function() {
            $('#secretButton').css('z-index', 999);
            $('#fullBody').css('position', 'relative');
          });
        }
