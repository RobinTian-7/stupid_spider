      <script>
        function changeGeo() {
          setGraphSrc("images/graphs/geoDensity.png");
          setGraphTxt('<b>Coursera CS1 Geographic Density:</b> this graph shows all 100K users in the coursera intro CS course linked by physical distance. Students within 1 km are combined into a single node.');
        }
        function changeCodeDotOrg() {
          setGraphSrc("images/graphs/codeDotOrgPolicy.png");
          setGraphTxt('<b>Code.org problem solving policy</b> graph of learned policy for how to solve a single open ended programming assignment from over 1M users. Each node is a unique partial-solution (and node 0 is the correct answer)');
        }
        function changeCodeWebs() {
          setGraphSrc("images/graphs/codeWebs.png");
          setGraphTxt('<b>Coursera Machine Learning Code Web:</b> Submissions from 40K students to logistic regression. Edge strength is inverse of abstract syntax tree edit distance. Node size is number of students.' );
        }
        function changePeer() {
          setGraphSrc("images/graphs/peerGrading.png");
          setGraphTxt('<b>Coursera HCI Peer Grading:</b> A peer grading network of 63K peer grades for 7K students in an online course. A single student is highlighted, red squares graded the student, red circles were graded by the student.');
        }
        function changeDeconstructing() {
          setGraphSrc("images/graphs/deconstructing.png");
          setGraphTxt('');
        }
        function changeCheckerboard() {
          setGraphSrc("images/graphs/checkerboardKarel.jpg");
          setGraphTxt('<b>CS106A clustered transitions:</b> Transitions between 6K submissions from 400 students in Stanford\'s intro to CS course. Nodes are clusters of API calls for partial solutions. Edges are proportional to humber of student transitions. S is start. G is goal. Nodes like 16 and 0 are sink states.');
        }

        function changeBlossoms() {
          setGraphSrc("images/graphs/blossoms.png");
          setGraphTxt('<b>Code.org Learning Blossoms:</b> This graphic is a screen shot of an animation that shows 509,405 students solving the third challenge in the code.org hour of code. The pink dots are students. See the <a href="http://stanford.edu/~cpiech/demos/research/blossoms.html">demo website</a> for the animation.');
        }

        function setGraphSrc(newSrc) {
          $("#graph").attr("src", newSrc);
        }

        function setGraphTxt(newTxt) {
          $("#graphTag").html(newTxt);
        }

