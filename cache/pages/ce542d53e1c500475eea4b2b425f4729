    <script>
        function showbib(id) {
            var x = document.getElementById(id);
            if (x.style.display === "none") {
                x.style.display = "block";
            } else {
                x.style.display = "none";
            }
        }

	/* Toggle between adding and removing the "responsive" class to topnav when the user clicks on the icon */
	function respFunction() {
		var x = document.getElementById("myTopnav");
		if (x.className === "topnav") {
			x.className += " responsive";
		} else {
			x.className = "topnav";
		}
	}

	function onNavClick(id) {
		var allNavItems = document.getElementById("myTopnav").children;
		for (i=0; i<allNavItems.length - 1; i++) {
			if (allNavItems[i].id == id) {
				allNavItems[i].classList.add("active");
			} else {
				allNavItems[i].classList.remove("active");
			}
		}
	}

	// When the user scrolls the page, execute myFunction
	window.onscroll = function() {stickyFunction()};

	// Get the navbar
	var navbar = document.getElementById("myTopnav");

	// Get the offset position of the navbar
	var sticky = navbar.offsetTop;

	// Add the sticky class to the navbar when you reach its scroll position. Remove "sticky" when you leave the scroll position
	function stickyFunction() {
		if (window.pageYOffset >= sticky) {
			navbar.classList.add("sticky")
		} else {
			navbar.classList.remove("sticky");
		}
	}
    </script>




