<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> <!-- Ensures responsiveness -->
    <title>Adam R. Klivans - Professor of Computer Science</title>

    <!-- Link to Google Fonts for Press Start 2P -->
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Press Start 2P', cursive;
            margin: 20px;
            padding: 20px;
            text-align: center;
            background-color: #000; /* Black background for retro arcade feel */
            color: #fff; /* Bright text color */
            border: 5px solid #00ff00; /* Bright green arcade border */
        }

        h1, h2, h3 {
            text-transform: uppercase;
            color: #ffcc00; /* Bright yellow for arcade style */
            text-shadow: 2px 2px #ff0000; /* Red shadow for retro look */
        }

        h1 {
            font-size: 32px;
            margin-bottom: 10px;
        }

        h2 {
            font-size: 22px;
            margin-bottom: 40px;
        }

	 /* NEW: chair title styling */
        .chair {
            font-size: 13px;
            color: #e6b800;
            text-shadow: 1px 1px #ff0000;
            margin-top: -25px;    /* just a little under Professor line */
            margin-bottom: 35px; /* clear space before Director block */
        }


        .director {
            font-size: 20px;
            color: #ffcc00;
            text-shadow: 1px 1px #ff0000;
            margin-bottom: 20px;
        }

        /* Add more space between director lines */
        .director .ifml-link {
            margin-bottom: 30px;
            display: inline-block;
        }

        /* Invert colors on hover for IFML and Machine Learning Lab links */
        .director a {
            color: #00ffff;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .director a:hover {
            background-color: #00ffff;
            color: #000;
            text-decoration: none;
            padding: 5px;
            border-radius: 5px;
        }

        section {
            margin-top: 50px;
        }

        /* Paper buttons with "Papers" underneath "All" */
        .paper-buttons {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap; /* Allows wrapping for smaller screens */
        }

        .paper-buttons a {
            color: #00ff00;
            text-decoration: none;
            padding: 10px 20px;
            background-color: #333;
            border-radius: 10px;
            text-shadow: 1px 1px #ff0000;
            transition: all 0.3s ease;
            width: 150px; /* Ensures button width is consistent */
            margin-bottom: 10px;
        }

        .paper-buttons a:hover {
            background-color: #00ff00;
            color: #333;
            text-shadow: none;
        }

        .all-papers {
            display: block;
            text-align: center;
        }

        .all-papers span {
            display: block; /* Make "Papers" appear underneath "All" */
        }

        /* Students and postdocs as they appeared in Q1 */
        .students, .postdocs, .scientist {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 30px;
            flex-wrap: wrap; /* Allows flex items to wrap on smaller screens */
        }

        .students a, .postdocs a, .scientist a {
            color: #00ff00;
            text-decoration: none;
            padding: 10px;
            background-color: #333;
            border-radius: 10px;
            transition: all 0.3s ease;
            width: 220px; /* Consistent width for students and postdocs */
            margin-bottom: 10px;
        }

        .students a:hover, .postdocs a:hover, .scientist a:hover {
            background-color: #00ff00;
            color: #333;
            text-shadow: none;
        }

        /* Former students section */
        .former-students {
            margin-top: 50px;
        }

        .former-students ul {
            list-style-type: none;
            padding: 0;
            margin: 0;
        }

        .former-students ul li {
            margin-bottom: 10px;
        }

        /* Adjusted to ensure all boxes are the same size */
        .former-students a {
            color: #00ff00;
            text-decoration: none;
            display: inline-block;
            padding: 10px;
            background-color: #333;
            border-radius: 10px;
            font-size: 18px;
            transition: all 0.3s ease;
            width: 220px; /* Set width for uniform box size */
            margin-bottom: 10px;
        }

        .former-students a:hover {
            background-color: #00ff00;
            color: #333;
            text-shadow: none;
        }

        /* Research Interests style */
        .research-interests {
            margin-top: 30px;
            font-size: 18px;
            color: #ffcc00;
            text-shadow: 1px 1px #ff0000;
            line-height: 1.8;
        }

        /* For More Information section style */
        .more-info {
            margin-top: 50px;
            font-size: 14px;
            color: #ffcc00;
            text-shadow: 1px 1px #ff0000;
        }

        .more-info a {
            color: #00ffff;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .more-info a:hover {
            background-color: #00ffff;
            color: #000;
            padding: 5px;
            border-radius: 5px;
        }

        /* Texas flag image styling */
        .texas-flag {
            margin-top: 30px;
        }

        .texas-flag img {
            width: 200px;
            height: auto;
            image-rendering: pixelated;
            border: 3px solid #00ff00;
            border-radius: 10px;
        }

        /* Media query for smaller screens (iPhone) */
        @media (max-width: 600px) {
            h1 {
                font-size: 24px; /* Reduce heading size on smaller screens */
            }

            h2 {
                font-size: 18px; /* Reduce subheading size */
            }

            .director, .research-interests, .more-info {
                font-size: 16px; /* Adjust font sizes for smaller screens */
            }

            /* Ensure buttons fit smaller screens */
            .paper-buttons a, .students a, .postdocs a, .scientist a, .former-students a {
                width: 100%; /* Make the buttons take up full width on small screens */
            }
        }
    </style>
</head>
