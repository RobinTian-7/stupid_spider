															<img loading="lazy" decoding="async" width="1000" height="1000" src="https://datascience.hku.hk/wp-content/uploads/2022/10/photo-YiMa4-sq.jpg" class="attachment-large size-large wp-image-5838" alt="" srcset="https://datascience.hku.hk/wp-content/uploads/2022/10/photo-YiMa4-sq.jpg 1000w, https://datascience.hku.hk/wp-content/uploads/2022/10/photo-YiMa4-sq-300x300.jpg 300w, https://datascience.hku.hk/wp-content/uploads/2022/10/photo-YiMa4-sq-150x150.jpg 150w, https://datascience.hku.hk/wp-content/uploads/2022/10/photo-YiMa4-sq-768x768.jpg 768w, https://datascience.hku.hk/wp-content/uploads/2022/10/photo-YiMa4-sq-500x500.jpg 500w" sizes="(max-width: 1000px) 100vw, 1000px" />															</div>
